{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/submit", "destination": "/api/submit" },
    { "source": "/", "destination": "/home" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home12", "destination": "/", "permanent": true },
    { "source": "/oldhome", "destination": "/", "permanent": true },
    { "source": "/ig", "destination": "/", "permanent": true },
    { "source": "/sellerguide", "destination": "/seller", "permanent": true },
    { "source": "/buyerguide", "destination": "/buyer", "permanent": true },
    { "source": "/equityreport", "destination": "/valuation", "permanent": true },
    { "source": "/helpmemove", "destination": "/zoom", "permanent": true },
    { "source": "/contact", "destination": "/zoom", "permanent": true },
    { "source": "/contact2", "destination": "/zoom", "permanent": true },
    { "source": "/connect", "destination": "/zoom", "permanent": true },
    { "source": "/gallery", "destination": "/listings", "permanent": true },
    { "source": "/property", "destination": "/listings", "permanent": true },
    { "source": "/resume", "destination": "/about", "permanent": true },
    { "source": "/es/index.html", "destination": "/es/", "permanent": true },
    { "source": "/es/index", "destination": "/es/", "permanent": true },
    { "source": "/es/comprador.html", "destination": "/es/comprador", "permanent": true },
    { "source": "/es/vendedor.html", "destination": "/es/vendedor", "permanent": true },
    { "source": "/es/valuacion.html", "destination": "/es/valuacion", "permanent": true },
    { "source": "/es/listados.html", "destination": "/es/listados", "permanent": true },
    { "source": "/es/guia.html", "destination": "/es/guia", "permanent": true }
  ],
  "crons": [
    {
      "path": "/api/rates",
      "schedule": "0 16 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400, must-revalidate" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|robots\\.txt|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
